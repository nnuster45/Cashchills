# CASHEW App - Environment Variables Template
# Copy this file to .env and fill in your values

# Database
DATABASE_PROVIDER=mongodb
DATABASE_NAME=cashchill
DATABASE_URL=mongodb://localhost:27017/cashchill
APP_JWT_SECRET=replace-with-a-long-random-secret

# LINE LIFF / LINE Login
NEXT_PUBLIC_LINE_LIFF_ID=
LINE_CHANNEL_ID=

# Google OAuth / Gmail Sync
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/integrations/google/callback
